{
  "name": "gradient",
  "private": true,
  "version": "1.0.3",
  "description": "a nice css background",
  "author": "Poran Dip",
  "license": "Apache-2.0",
  "scripts": {
    "lint:css": "stylelint \"**/*.css\"",
    "lint:js": "biome ci .",
    "clean": "rimraf dist",
    "prebuild": "npm run clean && mkdirp dist",
    "build:assets": "cp -r assets/* dist/assets/",
    "build:html": "html-minifier-terser src/index.html -o dist/index.html --collapse-whitespace --remove-comments --minify-css true --minify-js true",
    "build:css": "csso src/styles.css --output dist/styles.css",
    "build:js": "terser src/script.js -o dist/script.js --compress --mangle",
    "build": "npm run build:assets && npm run build:html && npm run build:css && npm run build:js",
    "test": "playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "csso-cli": "^4.0.2",
    "html-minifier-terser": "^7.2.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^6.1.3",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.46.1"
  }
}
